<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.sortingvisual.Controllers.Visualizationcontroller"
      styleClass="root"
      spacing="0"
      prefWidth="1100" prefHeight="740">

    <!-- ── Top Control Panel ──────────────────────────────────────────── -->
    <VBox styleClass="input-section" spacing="12">
        <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>

        <Label text="▸ SORTING VISUALIZATION" styleClass="title-label"/>

        <HBox spacing="20" alignment="CENTER_LEFT">

            <!-- Input Array -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="INPUT ARRAY  (integers, comma-separated  ·  supports negatives &amp; zero  ·  max 100)" styleClass="section-label"/>
                <TextField fx:id="vis_tfInput" prefHeight="34"
                           promptText="e.g.  38, -5, 72, 0, -19, 45, 13, -3, 60, 27"/>
            </VBox>

            <!-- Speed -->
            <VBox spacing="5" minWidth="180">
                <Label text="FRAME DELAY" styleClass="section-label"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="FAST" styleClass="speed-label"/>
                    <Slider fx:id="vis_sliderSpeed" min="10" max="600" value="120"
                            prefWidth="140" styleClass="slider"/>
                    <Label text="SLOW" styleClass="speed-label"/>
                    <Label fx:id="vis_speedLabel" text="120 ms" styleClass="speed-label"
                           minWidth="60"/>
                </HBox>
            </VBox>

        </HBox>

        <!-- Buttons + status -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Button fx:id="vis_btnVisualize" text="▶  VISUALIZE ALL"
                    onAction="#onVisualize" styleClass="btn-primary"/>
            <Button fx:id="vis_btnStop"      text="■  STOP"
                    onAction="#onStop"      styleClass="btn-danger" disable="true"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="vis_statusLabel" text="Enter numbers and click VISUALIZE ALL."
                   styleClass="stat-label"/>
        </HBox>

    </VBox>

    <!-- ── 2 × 3 Visualization Grid ──────────────────────────────────── -->
    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" fitToHeight="true"
                styleClass="scroll-pane" hbarPolicy="NEVER">
        <GridPane styleClass="vis-grid-pane" hgap="20" vgap="20">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <!-- Column constraints: 2 equal columns -->
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints vgrow="ALWAYS" minHeight="240"/>
                <RowConstraints vgrow="ALWAYS" minHeight="240"/>
                <RowConstraints vgrow="ALWAYS" minHeight="240"/>
            </rowConstraints>

            <!-- ── Cell 0,0 — Bubble Sort ─────────────────────────── -->
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="0"
                  styleClass="vis-cell" spacing="8">
                <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="BUBBLE SORT" styleClass="vis-algo-header color-bubble"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="vis_done_bubble" text="● IDLE" styleClass="stats-mini neon-teal"/>
                </HBox>
                <Canvas fx:id="vis_canvas_bubble" width="480" height="170" VBox.vgrow="ALWAYS"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="vis_cmp_bubble" text="CMP: 0" styleClass="stat-badge stat-badge-cmp"/>
                    <Label fx:id="vis_swp_bubble" text="SWP: 0" styleClass="stat-badge stat-badge-swp"/>
                </HBox>
            </VBox>

            <!-- ── Cell 1,0 — Selection Sort ──────────────────────── -->
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0"
                  styleClass="vis-cell" spacing="8">
                <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="SELECTION SORT" styleClass="vis-algo-header color-selection"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="vis_done_selection" text="● IDLE" styleClass="stats-mini neon-pink"/>
                </HBox>
                <Canvas fx:id="vis_canvas_selection" width="480" height="170" VBox.vgrow="ALWAYS"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="vis_cmp_selection" text="CMP: 0" styleClass="stat-badge stat-badge-cmp"/>
                    <Label fx:id="vis_swp_selection" text="SWP: 0" styleClass="stat-badge stat-badge-swp"/>
                </HBox>
            </VBox>

            <!-- ── Cell 0,1 — Insertion Sort ──────────────────────── -->
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1"
                  styleClass="vis-cell" spacing="8">
                <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="INSERTION SORT" styleClass="vis-algo-header color-insertion"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="vis_done_insertion" text="● IDLE" styleClass="stats-mini neon-gold"/>
                </HBox>
                <Canvas fx:id="vis_canvas_insertion" width="480" height="170" VBox.vgrow="ALWAYS"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="vis_cmp_insertion" text="CMP: 0" styleClass="stat-badge stat-badge-cmp"/>
                    <Label fx:id="vis_swp_insertion" text="SWP: 0" styleClass="stat-badge stat-badge-swp"/>
                </HBox>
            </VBox>

            <!-- ── Cell 1,1 — Quick Sort ───────────────────────────── -->
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="1"
                  styleClass="vis-cell" spacing="8">
                <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="QUICK SORT" styleClass="vis-algo-header color-quick"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="vis_done_quick" text="● IDLE" styleClass="stats-mini"/>
                </HBox>
                <Canvas fx:id="vis_canvas_quick" width="480" height="170" VBox.vgrow="ALWAYS"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="vis_cmp_quick" text="CMP: 0" styleClass="stat-badge stat-badge-cmp"/>
                    <Label fx:id="vis_swp_quick" text="SWP: 0" styleClass="stat-badge stat-badge-swp"/>
                </HBox>
            </VBox>

            <!-- ── Cell 0,2 — Merge Sort ───────────────────────────── -->
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="2"
                  styleClass="vis-cell" spacing="8">
                <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="MERGE SORT" styleClass="vis-algo-header color-merge"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="vis_done_merge" text="● IDLE" styleClass="stats-mini"/>
                </HBox>
                <Canvas fx:id="vis_canvas_merge" width="480" height="170" VBox.vgrow="ALWAYS"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="vis_cmp_merge" text="CMP: 0" styleClass="stat-badge stat-badge-cmp"/>
                    <Label fx:id="vis_swp_merge" text="SWP: 0" styleClass="stat-badge stat-badge-swp"/>
                </HBox>
            </VBox>

            <!-- ── Cell 1,2 — Heap Sort ────────────────────────────── -->
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="2"
                  styleClass="vis-cell" spacing="8">
                <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="HEAP SORT" styleClass="vis-algo-header color-heap"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="vis_done_heap" text="● IDLE" styleClass="stats-mini"/>
                </HBox>
                <Canvas fx:id="vis_canvas_heap" width="480" height="170" VBox.vgrow="ALWAYS"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="vis_cmp_heap" text="CMP: 0" styleClass="stat-badge stat-badge-cmp"/>
                    <Label fx:id="vis_swp_heap" text="SWP: 0" styleClass="stat-badge stat-badge-swp"/>
                </HBox>
            </VBox>

        </GridPane>
    </ScrollPane>

</VBox>
